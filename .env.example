# ── WizCodes Blog Agent — environment ──
# Copy to `.env` for local runs. On Render, set these as service env vars / secrets.
# NEVER commit the real .env (it is gitignored).

# ── Claude-compatible proxy (ClaudeStore) ──
# Anthropic Messages API shape. The proxy's Cloudflare blocks non-CLI clients,
# so llm/client.py always sends a CLI User-Agent (handled in code, no config).
ANTHROPIC_BASE_URL=https://api3.claudestore.store
ANTHROPIC_API_KEY=sk-cs2-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4.6
ANTHROPIC_SMALL_FAST_MODEL=claude-haiku-4.5

# ── GitHub publishing ──
# Fine-grained Personal Access Token scoped to ONLY the wizcodes repo,
# with Contents: Read and write. The agent commits posts straight to `main`.
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=wizcodes12/wizcodes_next
GITHUB_BRANCH=main
GIT_AUTHOR_NAME=WizCodes Blog Bot
GIT_AUTHOR_EMAIL=business@wizcodes.site

# ── Publishing cadence (human-like, anti-flag) ──
# Max posts/day and the local timezone the schedule windows are expressed in.
MAX_POSTS_PER_DAY=2
AVG_POSTS_PER_DAY=1.3
PUBLISH_WINDOW_START=8      # earliest hour (local tz) a post may go live
PUBLISH_WINDOW_END=22       # latest hour
MIN_GAP_HOURS=4            # minimum spacing between two same-day posts
SCHEDULE_TZ=Asia/Kolkata

# ── Uniqueness gate thresholds (cosine similarity, 0..1) ──
TOPIC_SIM_THRESHOLD=0.82    # reject a proposed topic if this close to an existing one
BODY_SIM_THRESHOLD=0.86     # hard-fail a finished draft if this close to any post

# ── Behaviour flags ──
# DRY_RUN=1 → generate to output/ and never touch git (safe for local testing).
DRY_RUN=1
LOG_LEVEL=INFO
